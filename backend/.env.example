# Usta backend ortam değişkenleri (USTA_ ön ekiyle okunur).
# Kopyala: cp .env.example .env

# Veritabanı (MVP: tek Postgres; geliştirmede SQLite varsayılan)
USTA_DATABASE_URL=sqlite+aiosqlite:///./usta.db
# Prod örneği:
# USTA_DATABASE_URL=postgresql+asyncpg://usta:parola@localhost:5432/usta

# JWT — PROD'da mutlaka değiştir (>=32 bayt)
USTA_JWT_SECRET=dev-secret-degistir-beni-en-az-32-bayt-olsun-prod

# Claude API (vision + ses analizi). Vision modeli sonnet'tir; Opus YASAK.
USTA_ANTHROPIC_API_KEY=
USTA_VISION_MODEL=claude-sonnet-4-5
USTA_AUDIO_MODEL=claude-sonnet-4-5

# Davranış
USTA_DEBUG=true
USTA_RATE_LIMIT_PER_MINUTE=30
