{
  "expo": {
    "name": "Usta",
    "slug": "usta",
    "scheme": "usta",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.usta.app",
      "userInterfaceStyle": "dark",
      "infoPlist": {
        "UIBackgroundColor": "#16181D"
      }
    },
    "android": {
      "package": "com.usta.app",
      "userInterfaceStyle": "dark",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#16181D"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Usta kamerayı doğru parçayı bulduğunu doğrulamak için kullanır.",
          "microphonePermission": "Usta mikrofonu canlı sesli rehberlik için kullanır.",
          "recordAudioAndroid": true
        }
      ],
      "expo-font",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#16181D"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "78ea62dc-1ba8-426b-8c56-0da737951693"
      }
    },
    "owner": "ahyazgan"
  }
}
